# Copy to `.env.local` and fill in secrets (`.env.local` is gitignored).

# Default PostgreSQL URL (adjust host/port/user/database as needed)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/election_db

# Express API (`ElectionSitrep/server`) — same DATABASE_URL; generate a strong secret for production
JWT_SECRET=change-me-in-production
# PORT=5530

# Production (nginx): exact browser origin for CORS — scheme + host + port users open (no path).
# FRONTEND_ORIGIN=http://YOUR_PUBLIC_IP:5535

# Optional: if the SPA calls the API on another origin (no Vite proxy), set the API base for production / mobile builds:
# VITE_API_BASE_URL=http://localhost:5530
# Legacy alias (still supported):
# VITE_API_URL=http://localhost:5530
#
# Android emulator reaching the API on your PC (same machine): http://10.0.2.2:5530
# Physical device on LAN: http://YOUR_PC_LAN_IP:5530 — rebuild web (`npm run build`) after changing this.

# Optional: PostgreSQL client binaries on Windows (for scripts / tooling)
POSTGRES_BIN=C:\Program Files\PostgreSQL\18\bin
